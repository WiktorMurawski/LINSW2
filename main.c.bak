#include <gpiod.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <ctype.h>

#define DOT_TIME     200000   // µs
#define DASH_TIME    (3 * DOT_TIME)
#define SYMBOL_SPACE DOT_TIME
#define LETTER_SPACE (3 * DOT_TIME)
#define WORD_SPACE   (7 * DOT_TIME)

const char *morse_codes[36] = {
    ".-", "-...", "-.-.", "-..", ".", // ABCDE 
    "..-.", "--.", "....", "..", ".---", // FGHIJ
    "-.-", ".-..", "--", "-.", "---", // KLMNO
    ".--.", "--.-", ".-.", "...", "-", // PQRST
    "..-", "...-", ".--", "-..-", "-.--", "--..", // UVWXYZ
    "-----", ".----", "..---", "...--", "....-", // 01234 
    ".....", "-....", "--...", "---..", "----.", // 56789
};

const char *morse_chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";

// ==================== TABLICA MORSE'A ====================
void print_morse_table(void)
{
    for (int i = 0; i < 18; i++) {
        printf(" %c   | %-15s ", morse_chars[i], morse_codes[i]);
        int j = i + 18;
        if (j < 36) {
            printf(" %c   | %-15s", morse_chars[j], morse_codes[j]);
        }
        printf("\n");
    }
    printf("======================================\n\n");
}

// ==================== FUNKCJE MORSE ====================
void morse_delay(int us) {
    usleep(us);
}

void flash(struct gpiod_line *led_line, const char *code) {
    for (const char *p = code; *p; p++) {
        gpiod_line_set_value(led_line, 1);

        if (*p == '.')      morse_delay(DOT_TIME);
        else if (*p == '-') morse_delay(DASH_TIME);

        gpiod_line_set_value(led_line, 0);
        morse_delay(SYMBOL_SPACE);
    }
}

void send_morse(struct gpiod_line *led_line, const char *text) {
    for (const char *p = text; *p; p++) {
        char c = toupper(*p);

        if (c == ' ') {
            morse_delay(WORD_SPACE - LETTER_SPACE);
            continue;
        }

        int idx = -1;
        if (c >= 'A' && c <= 'Z') idx = c - 'A';
        else if (c >= '0' && c <= '9') idx = c - '0' + 26;

        if (idx >= 0 && idx < 36) {
            flash(led_line, morse_codes[idx]);
            morse_delay(LETTER_SPACE - SYMBOL_SPACE);
        }
    }
}

// ==================== HELP ====================
void print_usage(const char *progname)
{
    printf("Użycie: %s [chipname] [line_number]\n", progname);
    printf("       %s --help\n\n", progname);
    printf("Domyślnie: gpiochip0 linia 17\n");
    printf("Przykład:  %s gpiochip0 23\n", progname);
    printf("           %s gpiochip4 5     (np. na Raspberry Pi 5)\n\n", progname);
}

// ==================== MAIN ====================
int main(int argc, char **argv)
{
    const char *chipname = "gpiochip0";   // domyślna wartość
    unsigned int line_num = 17;           // domyślna linia

    // Obsługa argumentów
    if (argc >= 2) {
        if (strcmp(argv[1], "--help") == 0 || strcmp(argv[1], "-h") == 0) {
            print_usage(argv[0]);
            return 0;
        }
        chipname = argv[1];
    }

    if (argc >= 3) {
        line_num = (unsigned int)strtoul(argv[2], NULL, 10);
    }

    // Otwieranie GPIO
    struct gpiod_chip *chip = gpiod_chip_open_by_name(chipname);
    if (!chip) {
        fprintf(stderr, "Błąd: Nie można otworzyć chipu '%s'\n", chipname);
        fprintf(stderr, "Sprawdź dostępne chipy poleceniem: gpiodetect\n");
        return 1;
    }

    struct gpiod_line *led_line = gpiod_chip_get_line(chip, line_num);
    if (!led_line) {
        fprintf(stderr, "Błąd: Nie można pobrać linii %u z chipu %s\n", line_num, chipname);
        gpiod_chip_close(chip);
        return 1;
    }

    if (gpiod_line_request_output(led_line, "morse_led", 0) < 0) {
        fprintf(stderr, "Błąd: Nie można skonfigurować linii %u jako wyjście\n", line_num);
        gpiod_chip_close(chip);
        return 1;
    }

    // Wyświetlenie informacji o uruchomieniu
    printf("Morse LED uruchomiony → chip: %s, linia: %u\n", chipname, line_num);
    print_morse_table();

    printf("Wpisz tekst i naciśnij Enter (pusta linia lub Ctrl+D kończy program).\n\n");

    char line[256];
    while (fgets(line, sizeof(line), stdin)) {
        line[strcspn(line, "\n")] = 0;

        if (strlen(line) == 0) break;

        printf("Nadaję: \"%s\"\n", line);
        send_morse(led_line, line);
        morse_delay(WORD_SPACE);
    }

    // Sprzątanie
    gpiod_line_release(led_line);
    gpiod_chip_close(chip);

    printf("\nKoniec programu.\n");
    return 0;
}
